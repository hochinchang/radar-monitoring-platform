[Unit]
Description=Radar Monitoring Platform
After=network.target

[Service]
Type=simple
User=radar
WorkingDirectory=/opt/radar-monitoring-platform
ExecStart=/opt/radar-monitoring-platform/venv/bin/uvicorn backend.main:app --host 0.0.0.0 --port 8000
Restart=on-failure
RestartSec=5
StandardOutput=journal
StandardError=journal

[Install]
WantedBy=multi-user.target
